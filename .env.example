# Exemple de configuration — copiez ce fichier en `.env` et ajustez.
# Toutes les variables sont préfixées DAA_ (pydantic-settings). Les valeurs
# ci-dessous sont les défauts du code (config.py) : décommentez pour surcharger.

# --- LLM mutualisé (Ollama, endpoint OpenAI-compatible) ---
# Service Ollama CENTRAL (repo llm-service) : lancer `make up` dans llm-service ;
# il publie Ollama sur le port hôte 11434 → l'URL par défaut ci-dessous pointe
# déjà dessus. Le central sert gemma4:e4b ; qwen3-coder:30b n'est disponible que
# si tu l'ajoutes à OLLAMA_MODELS du central (sinon utilise gemma4:e4b).
#DAA_OLLAMA_BASE_URL=http://localhost:11434/v1
#DAA_LLM_MODEL=gemma4:e4b
#DAA_LLM_TEMPERATURE=0.0
# Astuce dev CPU / WSL2 : un modèle plus léger + num_thread limité est bien
# plus rapide. Créez un modèle dérivé (Modelfile : `FROM qwen3.5:4b` +
# `PARAMETER num_thread 8`) et pointez-le ici, p. ex. :
#DAA_LLM_MODEL=qwen3.5-demo:4b

# --- Agent Récupération ---
#DAA_CATALOG_PATH=sources/catalogue.yaml
#DAA_RETRIEVAL_MAX_ROWS=200
#DAA_RETRIEVAL_REQUEST_LIMIT=10

# --- Agent Analyse ---
#DAA_ANALYSIS_MAX_ATTEMPTS=3
#DAA_ANALYSIS_TABLE_MAX_ROWS=10000

# --- Inférence ML ---
#DAA_MODELS_REGISTRY_PATH=models/registry.yaml

# --- Mémoire de conversation ---
# Chaque conversation persiste ses tableaux intermédiaires (CSV) sous ce dossier
# pour les réutiliser aux tours suivants (« prédis ces lignes », code d'analyse).
#DAA_WORKSPACE_DIR=/tmp/daa-workspaces

# --- Sandbox d'exécution (Docker, réseau coupé) ---
# JSON pour les listes ; sous Windows, exécuter docker via WSL :
#DAA_SANDBOX_DOCKER_CMD=["docker"]
#DAA_SANDBOX_DOCKER_CMD=["wsl","docker"]
#DAA_SANDBOX_IMAGE=data-analyst-agent-sandbox:0.1
#DAA_SANDBOX_MEM_LIMIT=1g
#DAA_SANDBOX_CPUS=1.0
#DAA_SANDBOX_PIDS_LIMIT=256
#DAA_SANDBOX_START_TIMEOUT=60.0
#DAA_SANDBOX_EXEC_TIMEOUT=30.0
#DAA_SANDBOX_KILL_GRACE=10.0

# --- Source Postgres (référencée par ${...} dans sources/catalogue.yaml) ---
# À renseigner uniquement si vous déclarez une source de type postgres.
# Contrairement aux réglages ci-dessus, ces variables ne sont pas des champs de
# Settings : elles sont publiées dans l'environnement du process (config.py,
# export_env_file) parce que le DSN du catalogue est résolu par expandvars.
#DAA_PG_HOST=localhost
#DAA_PG_PORT=5432
#DAA_PG_USER=postgres
#DAA_PG_PASSWORD=change-me
